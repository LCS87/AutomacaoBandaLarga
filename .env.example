# ============================================================
# Configurações do Pipeline AutomacaoBandaLarga
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o .env com credenciais reais
# ============================================================

# --- Script 2: API de Consulta CNPJ ---
CNPJ_API_KEY=sua_chave_aqui
CNPJ_API_URL=https://api.seuservico.com/v1/cnpj

# --- Rate Limiting ---
MAX_REQUESTS_PER_MINUTE=900
REQUEST_TIMEOUT=10
MAX_WORKERS=10

# --- Cache ---
CACHE_TTL_DAYS=30

# --- Logging ---
LOG_LEVEL=INFO

# --- Colunas (opcional, usa padrão se não definido) ---
CNPJ_COLUMN=DOCUMENTO
TELEFONE_COLUMN_HINT=telefone
